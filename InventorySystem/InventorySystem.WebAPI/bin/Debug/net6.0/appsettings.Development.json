{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Security": {
    "RequireAuthenticatedByDefault": true,
    "RequestsPerMinutePerIp": 300,
    "IdempotencyTtlMinutes": 5,
    "AllowedOrigins": [
      "http://localhost:4200"
    ]
  }
}
