{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=InventoryDb;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "Jwt": {
    "Key": "super_secret_key_that_is_long_enough_for_hmac_sha256",
    "Issuer": "Axonix.Inventory",
    "Audience": "Axonix.Inventory.Client"
  },
  "Security": {
    "RequireAuthenticatedByDefault": true,
    "RequestsPerMinutePerIp": 180,
    "IdempotencyTtlMinutes": 10,
    "AllowedOrigins": [
      "http://localhost:4200"
    ]
  },
  "Backup": {
    "BackupDirectory": "backups"
  },
  "Testing": {
    "UseInMemoryDatabase": false,
    "InMemoryDatabaseName": "default"
  },
  "Redis": {
    "ConnectionString": ""
  },
  "Commercial": {
    "EnforceSubscription": false
  },
  "Integrations": {
    "FeatureFlags": {
      "TallyConnectorEnabled": false,
      "GspConnectorEnabled": false
    },
    "Tally": {
      "Endpoint": ""
    },
    "Gsp": {
      "Endpoint": ""
    }
  }
}
